# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
LINKUP_API_KEY="MY_LINKUP_API_KEY"
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Admin (server-side, for the Chrome extension API at /api/extension/*).
# Pick ONE credential source — keep any secret value out of frontend bundles:
#   1. Keyless local dev (no key file needed; works even when the org blocks
#      service-account key creation):
#        gcloud auth application-default login
#      then set FIREBASE_PROJECT_ID below so Firestore knows the project.
#   2. Service-account JSON on one line (set this on Vercel):
#        FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'
#   3. Key file path: GOOGLE_APPLICATION_CREDENTIALS="/path/to/key.json"
FIREBASE_SERVICE_ACCOUNT=""
FIREBASE_PROJECT_ID="druid-pro-event-pipeline"
# Optional: only set if the data lives in a named (non-default) Firestore database.
FIREBASE_FIRESTORE_DATABASE_ID=""

# Firebase Client configuration environment variables (safe for frontend bundles)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
